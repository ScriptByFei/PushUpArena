# PushupArena – Environment-Variablen
#
# Kopiere diese Datei nach `.env` und trage die Werte aus deinem Supabase-Projekt ein
# (Supabase Dashboard → Project Settings → API).
#
# WICHTIG: Es darf NUR der öffentliche anon/publishable Key verwendet werden.
# Der Service-Role-/Secret-Key gehört NIEMALS ins Frontend.

# Projekt-URL, z. B. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Öffentlicher anon / publishable Key (beginnt mit "eyJ..." bzw. "sb_publishable_...")
VITE_SUPABASE_ANON_KEY=
